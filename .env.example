# Database Configuration
# PostgreSQL connection settings for the online exam platform
DB_USER=postgres
DB_HOST=localhost
DB_NAME=online_exam_final
DB_PORT=5432
DB_PASSWORD=your_secure_password_here

# Note: These environment variables are REQUIRED for the application to run
# Set DB_PASSWORD to a secure value before starting the application in production


# Google OAuth Configuration
# Create OAuth credentials at: https://console.developers.google.com/
# Required for authentication functionality
GOOGLE_CLIENT_ID=your_google_client_id_here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Groq API Configuration
# Get your API key from: https://console.groq.com/keys
# Used for AI-powered features in the platform
GROQ_API_KEY=your_groq_api_key_here
# OCR.space API key (optional) - used for extracting text from PNG/JPEG images
# Get one at: https://ocr.space/ocrapi
OCR_SPACE_API_KEY=your_ocr_space_api_key_here